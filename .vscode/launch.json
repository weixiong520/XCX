{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "桌面程序",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/desktop_main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "开发模式",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/desktop_dev.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "CLI 登录示例",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/desktop_py_cli.py",
      "args": [
        "login",
        "--account",
        "主账号"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "全部单元测试",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": [
        "discover",
        "-s",
        "py_tests",
        "-v"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "QT_QPA_PLATFORM": "offscreen"
      }
    }
  ]
}
